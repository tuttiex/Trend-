# Blockchain
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org
AGENT_WALLET_PRIVATE_KEY=
# Use encrypted key in production or local dev key

# Secret Manager (Production)
AWS_REGION=us-east-1
SECRET_NAME=autonomous-agent-keys

# Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Database
DATABASE_URL=

# Monitoring
ALERT_EMAIL=
LOG_LEVEL=info

# Groq LLM (Text AI - replaces Gemini)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Image Generation (SiliconFlow with FLUX-1.1-pro)
SILICONFLOW_API_KEY=
SILICONFLOW_IMAGE_MODEL=black-forest-labs/FLUX-1.1-pro

# Legacy (optional - kept as fallback if needed)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest


# Budget Constraints (Safety)
MAX_GAS_PER_DEPLOYMENT=
MAX_LIQUIDITY_PER_TOKEN=
MAX_DAILY_SPEND=

# Creator Fee (percentage of token supply, default: 1)
CREATOR_FEE_PERCENT=1
