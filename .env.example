# Use encrypted key in production or local dev key

# Secret Manager (Production)
AWS_REGION=us-east-1
SECRET_NAME=autonomous-agent-keys

# Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
